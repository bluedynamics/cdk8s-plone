        },
      },
      "template": {
        "metadata": {
          "labels": {
            "app": "plone-frontend-c88fef5c",
            "app.kubernetes.io/component": "frontend",
            "app.kubernetes.io/managed-by": "cdk8s-plone",
            "app.kubernetes.io/name": "plone-frontend",
            "app.kubernetes.io/part-of": "plone",
